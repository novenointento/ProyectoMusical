# ============ Base de datos (Neon Postgres) ============
# Cadena de conexion de Neon (con ?sslmode=require en produccion).
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Alternativa para desarrollo local con docker-compose:
# DATABASE_URL="postgresql://musical_user:musical_password@localhost:5432/musical_db"

# Variables usadas por docker-compose.yml (solo local).
DB_HOST=localhost
DB_PORT=5432
DB_USER=musical_user
DB_PASSWORD=musical_password
DB_NAME=musical_db

# ============ Auth.js v5 ============
# Generar con: openssl rand -base64 32
AUTH_SECRET=""

# Solo en produccion custom; en Vercel se deduce automaticamente.
# AUTH_URL="https://tu-dominio.com"

# ============ App ============
NEXT_PUBLIC_APP_URL="http://localhost:3000"
