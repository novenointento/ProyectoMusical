// Proyecto Musical - schema de dominio
// Contenido teorico/MDX vive en /content. Esta BD mantiene:
// - Identidad y sesion (Auth.js v5)
// - Indice jerarquico de cursos/temas/lecciones (metadata)
// - Ejercicios (config JSON validada por Zod segun ExerciseType)
// - Auditoria de intentos, progreso por leccion, logros

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth.js v5
// ============================================================
// Las tablas Account/Session se mantienen aun usando JWT, para
// habilitar OAuth en Fase 2 sin migracion destructiva.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  progress     UserProgress[]
  attempts     ExerciseAttempt[]
  achievements UserAchievement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Dominio musical (solo metadata - contenido en MDX)
// ============================================================

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  order       Int      @default(0)
  level       Level    @default(ELEMENTARY)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics Topic[]

  @@index([order])
}

model Topic {
  id          String   @id @default(cuid())
  courseId    String
  slug        String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, slug])
  @@index([courseId, order])
}

model Lesson {
  id               String     @id @default(cuid())
  topicId          String
  slug             String
  title            String
  description      String?
  order            Int        @default(0)
  difficulty       Difficulty @default(BEGINNER)
  estimatedMinutes Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  topic     Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  progress  UserProgress[]

  @@unique([topicId, slug])
  @@index([topicId, order])
}

model Exercise {
  id        String       @id @default(cuid())
  lessonId  String
  type      ExerciseType
  order     Int          @default(0)
  // Config tipada por Zod en lib/validation/schemas.ts segun `type`.
  // Ejemplo NoteRecognition: { clef, noteRange: { from, to }, optionCount }
  config    Json
  points    Int          @default(10)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  lesson   Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts ExerciseAttempt[]

  @@index([lessonId, order])
}

model ExerciseAttempt {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  // Instancia generada (reproducible por `seed`).
  input      Json
  // Respuesta del usuario.
  answer     Json
  correct    Boolean
  score      Int
  timeMs     Int?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([exerciseId])
}

model UserProgress {
  id                 String         @id @default(cuid())
  userId             String
  lessonId           String
  status             ProgressStatus @default(NOT_STARTED)
  score              Int            @default(0)
  completedExercises Int            @default(0)
  lastAttemptAt      DateTime?
  completedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, status])
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String?
  points      Int      @default(0)
  // Criterio evaluado por codigo. Ej: { "type": "LESSONS_COMPLETED", "count": 1 }
  criteria    Json
  createdAt   DateTime @default(now())

  unlockedBy UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ============================================================
// Enums
// ============================================================

enum Level {
  ELEMENTARY
  INTERMEDIATE
  ADVANCED
}

enum Difficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
}

enum ExerciseType {
  MULTIPLE_CHOICE
  NOTE_WRITING
  DICTATION
  LISTEN_REPEAT
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}
